{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "upload-route": {
        "ClusterId": "upload-cluster",
        "Match": {
          "Path": "/api/upload/{**catch-all}"
        }
      },
      "status-route": {
        "ClusterId": "orchestrator-cluster",
        "Match": {
          "Path": "/api/status/{**catch-all}"
        }
      },
      "report-route": {
        "ClusterId": "report-cluster",
        "Match": {
          "Path": "/api/report/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "upload-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://upload-service:8080"
          }
        }
      },
      "orchestrator-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://orchestrator-service:8080"
          }
        }
      },
      "report-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://report-service:8080"
          }
        }
      }
    }
  }
}
