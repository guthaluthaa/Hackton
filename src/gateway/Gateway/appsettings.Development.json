    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "ReverseProxy": {
    "Clusters": {
      "upload-cluster": {
        "Destinations": {
          "destination1": {
