# ============================================
# Hackton - Environment Variables
# Copy this file to .env and adjust as needed
# ============================================

# PostgreSQL
POSTGRES_USER=hackton
POSTGRES_PASSWORD=hackton123
POSTGRES_MULTIPLE_DATABASES=upload_db,orchestrator_db,report_db

# RabbitMQ
RABBITMQ_USER=hackton
RABBITMQ_PASSWORD=hackton123

# MinIO (Object Storage)
MINIO_ROOT_USER=hackton
MINIO_ROOT_PASSWORD=hackton123
MINIO_BUCKET=uploads

# Seq (Logging)
SEQ_ADMIN_PASSWORD=hackton123

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# LLM Provider: "claude" ou "openai"
LLM_PROVIDER=openai

# Claude AI
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-opus-4-5

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO
